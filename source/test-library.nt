import {
  core.list {append, length, reverse},
  core.string {pack, unpack},
  this.check {check},
  this.gen.float {float-gen},
  this.gen.int {int-gen},
  this.gen.list {list-gen},
  this.gen.one-of {one-of},
  this.gen.pair {pair-gen},
  this.gen.rune {rune-gen},
  this.gen.string {ascii-string-gen, string-gen},
  this.gen.vector {vector-gen},
  this.make-noa-kit {make-default-noa-kit, make-verbose-noa-kit},
  this.test {test},
}

define _find-int(i: int, xs: list(int)) -> bool {
  match xs {
  | Nil =>
    False
  | Cons(x, xs) =>
    if eq-int(x, i) {
      True
    } else {
      _find-int(i, xs)
    }
  }
}

define _find-int-vec(i: int, xs: vector(int)) -> bool {
  match core.vector.pop-front(xs) {
  | Left(_) =>
    False
  | Right(Pair(x, xs)) =>
    if eq-int(x, i) {
      True
    } else {
      _find-int-vec(i, xs)
    }
  }
}

define _find-float(i: float, xs: list(float)) -> bool {
  match xs {
  | Nil =>
    False
  | Cons(x, xs) =>
    if gt-float(x, i) {
      True
    } else {
      _find-float(i, xs)
    }
  }
}

define zen() -> unit {
  pin k = make-default-noa-kit();
  check::(
    k,
    "unpack then pack is identity",
    string-gen,
    (t) => {
      pin t = t;
      pin xs = unpack(t);
      pin t-new = pack(xs);
      eq-string(t, t-new)
    },
  );
  check::(
    k,
    "(length as string) == (length as listchars)",
    string-gen,
    (t) => {
      pin t = t;
      pin xs = unpack(t);
      let len1 = core.string.length(t);
      let len2 = length(xs);
      eq-int(len1, len2)
    },
  );
  check::(
    k,
    "reverse(ys) ++ reverse(xs) == reverse(xs ++ ys)",
    pair-gen(list-gen(rune-gen), list-gen(rune-gen)),
    (p) => {
      let Pair(!xs, !ys) = p;
      pin left = append(reverse(ys), reverse(xs));
      pin right = reverse(append(xs, ys));
      eq-data::(left, right)
    },
  );
  pin xs = List[1, 2, 3];
  pin x = 4;
  check::(
    k,
    "one-of (should fail)",
    one-of(xs, x),
    (x) => {
      let b1 = eq-int(x, 1);
      let b2 = eq-int(x, 3);
      let b3 = eq-int(x, 3);
      or(b1, or(b2, b3))
    },
  );
  check::(
    k,
    "shrinking strings (should fail)",
    string-gen,
    (t) => {
      let len on t = core.string.length(t);
      let _ = t;
      lt-int(len, 10)
    },
  );
  check::(
    k,
    "there is no list that contains 15 (should fail and report [15])",
    list-gen(int-gen),
    (xs) => {
      not(_find-int(15, xs))
    },
  );
  check::(
    k,
    "there is no list that contains a value bigger than 15 (should fail and report [15.XXXXXX])",
    list-gen(float-gen),
    (xs) => {
      not(_find-float(15, xs))
    },
  );
  pin kv = make-verbose-noa-kit();
  check::(
    kv,
    "there is no list that contains 15 (should fail and report [15])",
    vector-gen(int-gen),
    (xs) => {
      not(_find-int-vec(15, xs))
    },
  );
  check::(
    k,
    "ascii",
    ascii-string-gen,
    (_) => {
      True
    },
  );
  test(
    k,
    "the list `List[1, 2, 3]` contains 2",
    () => {
      pin xs = List[1, 2, 3];
      pin f =
        (y) => {
          eq-int(*y, 2)
        };
      let result = core.list.find(xs, f);
      match result {
      | Left(_) =>
        False
      | Right(_) =>
        True
      }
    },
  );
}

define main() -> unit {
  zen()
}
