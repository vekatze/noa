import {
  core.random {random-in-range-int},
  this.gen {Gen, gen},
}

define optional<a>(!g: gen(a)) -> gen(?a) {
  Gen {
    generate := {
      (size) => {
        let dice = random-in-range-int(0, 1);
        if eq-int(dice, 0) {
          none
        } else {
          let Gen {generate} = g;
          Right(generate(size))
        }
      }
    },
    shrink := {
      (_) => {
        Nil
      }
    },
  }
}
