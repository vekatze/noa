import {
  this.gen {gen},
  this.gen.custom.rune {gen-rune-in-range},
  this.gen.custom.string,
}

constant string-gen: gen(string) {
  this.gen.custom.string.string-gen(this.gen.custom.string.Config {
    min-length := 0,
    max-length := none,
    rune-generator := none,
    rune-acceptor := {
      (_) => {
        True
      }
    },
  })
}

constant ascii-string-gen: gen(string) {
  this.gen.custom.string.string-gen(this.gen.custom.string.Config {
    min-length := 0,
    max-length := none,
    rune-generator := {
      Right(() => {
        gen-rune-in-range(0x20, 0x7e)
      })
    },
    rune-acceptor := {
      (_) => {
        True
      }
    },
  })
}
