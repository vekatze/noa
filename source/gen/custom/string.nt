import {
  core.control {grow},
  core.either {from-right},
  core.foreign {UINT32_MAX},
  core.int {max-int, min-int},
  core.list {filter, for-each-N},
  core.random {random-in-range-int},
  core.string {join, pack, unpack},
  this.gen {Gen, gen},
  this.gen.custom.rune,
  this.gen.list {_shrink-list},
}

data config {
| Config(
    min-length: int,
    max-length: ?int,
    rune-generator: ?() -> rune,
    rune-acceptor: (rune) -> bool,
  )
}

inline string-gen(!c: config) -> gen(string) {
  let Config{rune-generator, rune-acceptor, max-length, min-length} = c;
  let rune-config =
    this.gen.custom.rune.Config{
      rune-generator,
      rune-acceptor,
    };
  let !rune-gen = this.gen.custom.rune.rune-gen(rune-config);
  let Gen{generate} = rune-gen;
  Gen{
    generate := {
      (size: int) => {
        let max-length = from-right(max-length, zext-int32-int(UINT32_MAX));
        let string-max-len = trunc-int-int32(min-int(size, max-length));
        let string-len = max-int(random-in-range-int(0, string-max-len), min-length);
        let tmp =
          grow(Nil, string-len, (acc, _) => {
            let r = generate(size);
            Cons(core.string.singleton(r), acc)
          });
        join(tmp)
      }
    },
    shrink := {
      (t: string) => {
        pin t = t;
        let rune-seq = unpack(t);
        pin rune-lists = _shrink-list(rune-gen)(rune-seq);
        let result = for-each-N(rune-lists, pack);
        filter(result, (t) => {
          let len = core.string.length(t);
          ge-int(len, min-length)
        })
      }
    },
  }
}
