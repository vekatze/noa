import {
  core.int {abs-int},
  core.list {for-each},
  core.random {random-in-range-int},
  this.gen {Gen, gen},
}

define _div-seq(k: int) -> list(int) {
  if eq-int(k, 0) {
    Nil
  } else {
    Cons(k, _div-seq(div-int(k, 2)))
  }
}

constant int-gen: gen(int) {
  Gen{
    generate := {
      (size) => {
        let size = trunc-int-int32(size);
        random-in-range-int(mul-int32(-1, size), size)
      }
    },
    shrink := {
      (x) => {
        let tmp =
          for-each(_div-seq(x), (diff) => {
            sub-int(x, diff)
          });
        if lt-int(x, 0) {
          Cons(abs-int(x), tmp)
        } else {
          tmp
        }
      }
    },
  }
}

constant positive-int-gen: gen(int) {
  Gen{
    generate := {
      (size) => {
        random-in-range-int(0, trunc-int-int32(size))
      }
    },
    shrink := {
      (x) => {
        for-each(_div-seq(x), (diff) => {
          sub-int(x, diff)
        })
      }
    },
  }
}

constant negative-int-gen: gen(int) {
  Gen{
    generate := {
      (size) => {
        let size = trunc-int-int32(size);
        mul-int(-1, random-in-range-int(0, size))
      }
    },
    shrink := {
      (x) => {
        for-each(_div-seq(x), (diff) => {
          sub-int(x, diff)
        })
      }
    },
  }
}
