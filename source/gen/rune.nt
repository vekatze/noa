import {
  this.gen {gen},
  this.gen.custom.rune {gen-rune-in-range},
}

constant rune-gen: gen(rune) {
  this.gen.custom.rune.rune-gen(this.gen.custom.rune.Config{
    rune-generator := none,
    rune-acceptor := {
      (_) => {
        True
      }
    },
  })
}

constant ascii-rune-gen: gen(rune) {
  this.gen.custom.rune.rune-gen(this.gen.custom.rune.Config{
    rune-generator := {
      Right(() => {
        gen-rune-in-range(0x20, 0x7e)
      })
    },
    rune-acceptor := {
      (_) => {
        True
      }
    },
  })
}
