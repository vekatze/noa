import {
  core.random {random-int32},
  this.gen {Gen, gen},
}

constant bool-gen: gen(bool) {
  Gen{
    generate := {
      (_) => {
        let i = random-int32(2);
        if eq-int32(i, 0) {
          False
        } else {
          True
        }
      }
    },
    shrink := {
      (x) => {
        if x {
          List[False]
        } else {
          List[]
        }
      }
    },
  }
}
