import {
  core.ansi {ansi-kit},
}

data noa-kit {
| _Noa-Kit(
    ansi-kit: ansi-kit,
    num-of-tests: int,
    max-size: int,
    verbose: bool,
  )
}

define _compute-size(k: &noa-kit, iteration: int) -> int {
  tie _Noa-Kit {num-of-tests, max-size} = k;
  let max-size-float = sitofp-int-float(*max-size);
  let iteration-float = sitofp-int-float(iteration);
  let num-of-tests-float = sitofp-int-float(*num-of-tests);
  let size = mul-float(max-size-float, div-float(iteration-float, num-of-tests-float));
  fptosi-float-int(size)
}

define do-nothing(_: &text) -> unit {
  Unit
}
